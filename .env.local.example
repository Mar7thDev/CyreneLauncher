# Copy this file to .env.local for personal-only launcher tweaks.
# Vite loads .env.local from the project root during development/builds.
# This repo ignores .env.local so local choices stay out of commits.
#
# Set a feature to false/off/0/no to hide it locally.
# Leave entries commented out to use the shared defaults in frontend/src/config/features.ts.

# VITE_FEATURE_NEWS=false
# VITE_FEATURE_LANGUAGE_TOOLS=false
# VITE_FEATURE_DIFF_TOOLS=false
# VITE_FEATURE_ANALYSIS=false
# VITE_FEATURE_SR_TOOLS=false
# VITE_FEATURE_CONSOLE=false
# VITE_FEATURE_HOW_TO=false
# VITE_FEATURE_ABOUT=false
# VITE_FEATURE_ACCOUNT=false
# VITE_FEATURE_EXTERNAL_TOOL_LINKS=false
# VITE_FEATURE_DISCORD_LINK=false
# VITE_FEATURE_HOME_LINK_FIREFLY_ANALYSIS=false
# VITE_FEATURE_HOME_LINK_FIREFLY_SRTOOLS=false
# VITE_FEATURE_HOME_LINK_AMAZING_SRTOOLS=true
# VITE_FEATURE_HOME_LINK_DISCORD=true
# VITE_FEATURE_HOME_LINK_HOW_TO=false
# VITE_FEATURE_BACKGROUND_SELECTOR=false
# VITE_FEATURE_GAME_PROFILE_SWITCHER=false

# Launcher skin and branding.
# These HoyoToon-style values came from C:\Github Projects\HoyoToon Launcher.
# VITE_LAUNCHER_APP_NAME="HoyoToon Launcher"
# VITE_LAUNCHER_APP_SUBTITLE="Custom subtitle"
# VITE_LAUNCHER_SUBTITLE_MODE="static"
# To show the selected game client's version in the header instead:
# VITE_LAUNCHER_SUBTITLE_MODE="game-version"
# VITE_LAUNCHER_GAME_VERSION_SUBTITLE_PREFIX="Game version"
# VITE_LAUNCHER_GAME_VERSION_UNKNOWN_SUBTITLE="Game version unknown"
# VITE_LAUNCHER_GAME_VERSION_MISSING_SUBTITLE="No game selected"
# VITE_LAUNCHER_APP_ICON="/local-appicon.png"
# VITE_LAUNCHER_BRANDED_CHROME=true
# VITE_LAUNCHER_PROJECT_AUTHOR="HoyoToon"
# VITE_LAUNCHER_PROJECT_REPO_URL="https://discord.gg/hoyotoon"
# VITE_LAUNCHER_DISCORD_URL="https://discord.gg/hoyotoon"
# VITE_LAUNCHER_DEFAULT_PATCH_URL="https://hsr.hoyotoon.com"
# VITE_LAUNCHER_DEFAULT_PATCH_SERVER_PORT=443
# VITE_LAUNCHER_GRADIENT_FROM="#5b0479"
# VITE_LAUNCHER_GRADIENT_VIA="#7d3fd1"
# VITE_LAUNCHER_GRADIENT_TO="#9e6bff"
# VITE_LAUNCHER_THEME_PRIMARY="#5b0479"
# VITE_LAUNCHER_THEME_SECONDARY="#9e6bff"
# VITE_LAUNCHER_THEME_ACCENT="#7d3fd1"
# VITE_LAUNCHER_BRAND_TEXT_COLOR="#5b0479"
# VITE_LAUNCHER_MUTED_TEXT_COLOR="#7d3fd1"
# VITE_LAUNCHER_THEME_SOFT_BACKGROUND_COLOR="color-mix(in srgb, #5b0479 9%, white 91%)"
# VITE_LAUNCHER_THEME_SOFT_BACKGROUND_STRONG_COLOR="color-mix(in srgb, #5b0479 16%, white 84%)"
# VITE_LAUNCHER_THEME_SOFT_BORDER_COLOR="color-mix(in srgb, #5b0479 26%, white 74%)"
# VITE_LAUNCHER_THEME_SOFT_SHADOW_COLOR="color-mix(in srgb, #5b0479 18%, transparent)"
# VITE_LAUNCHER_THEME_OVERLAY_BACKGROUND_COLOR="color-mix(in srgb, #5b0479 8%, transparent)"
# VITE_LAUNCHER_PANEL_BACKGROUND_COLOR="color-mix(in srgb, #5b0479 66%, #120014 34%)"
# VITE_LAUNCHER_PANEL_BORDER_COLOR="rgb(255 255 255 / 0.16)"
# VITE_LAUNCHER_PANEL_TEXT_COLOR="#ffffff"
# VITE_LAUNCHER_PANEL_HOVER_BACKGROUND_COLOR="rgb(255 255 255 / 0.12)"
# VITE_LAUNCHER_PANEL_HOVER_TEXT_COLOR="#ffffff"
# Optional: only set these when your local skin should also recolor DaisyUI
# neutral text/surfaces and semantic status colors.
# VITE_LAUNCHER_THEME_BASE_100_COLOR="color-mix(in srgb, #5b0479 4%, white 96%)"
# VITE_LAUNCHER_THEME_BASE_200_COLOR="color-mix(in srgb, #5b0479 9%, white 91%)"
# VITE_LAUNCHER_THEME_BASE_300_COLOR="color-mix(in srgb, #5b0479 16%, white 84%)"
# VITE_LAUNCHER_THEME_BASE_CONTENT_COLOR="color-mix(in srgb, #5b0479 24%, #0f1020 76%)"
# VITE_LAUNCHER_THEME_SUCCESS_COLOR="#7d3fd1"
# VITE_LAUNCHER_THEME_WARNING_COLOR="#9e6bff"
# VITE_LAUNCHER_THEME_ERROR_COLOR="#d94b86"
#
# Backgrounds can be public asset names from frontend/public or full image URLs.
# When VITE_LAUNCHER_BACKGROUND_OPTIONS is set, local builds remove unlisted
# bg-* files from frontend/dist before embedding the app.
# VITE_LAUNCHER_DEFAULT_BACKGROUND="bg-17.jpg"
# VITE_LAUNCHER_STARRAIL_BACKGROUND="bg-17.jpg"
# VITE_LAUNCHER_GENSHIN_BACKGROUND="bg-columbina.jpg"
# VITE_LAUNCHER_BACKGROUND_OPTIONS="bg-columbina.jpg,bg-17.jpg,bg-11.jpeg,bg-1.jpeg,bg-2.png,bg-3.png,bg-6.png,bg-7.jpeg,bg-8.png,bg-9.jpeg,bg-10.jpg,bg-12.jpg,bg-13.jpg,bg-16.jpg"

# Local build branding.
# Place your icon at .local/branding/appicon.png, or point LAUNCHER_BUILD_ICON
# at another local PNG path. The build task generates ignored local icons from it.
# LAUNCHER_VERSION="1.0.7"
# LAUNCHER_BUILD_EXE_NAME="hoyotoon-launcher"
# LAUNCHER_BUILD_ICON=".local/branding/appicon.png"
#
# Local updater control. The Windows build task bakes these values into ignored
# internal/buildconfig/local.json so distributed builds keep your update source.
# LAUNCHER_UPDATE_REPO="YourOrg/YourLauncher"
# If omitted with a custom repo, this is inferred from LAUNCHER_BUILD_EXE_NAME
# with spaces converted to dots.
# LAUNCHER_UPDATE_ASSET_NAME="hoyotoon-launcher.exe"
